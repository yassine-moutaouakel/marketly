{
  "info": {
    "name": "Marketly API",
    "description": "Collection Postman d'exemple pour la marketplace Marketly.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth / Register buyer",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"newbuyer@marketly.dev\",\n  \"password\": \"Buyer123!\",\n  \"firstName\": \"Nina\",\n  \"lastName\": \"Buyer\",\n  \"role\": \"BUYER\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "register"]
        }
      }
    },
    {
      "name": "Auth / Login buyer",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"buyer@marketly.dev\",\n  \"password\": \"Buyer123!\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "Products / List",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/products?search=casque",
          "host": ["{{baseUrl}}"],
          "path": ["products"],
          "query": [
            {
              "key": "search",
              "value": "casque"
            }
          ]
        }
      }
    },
    {
      "name": "Cart / Add item",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productId\": \"product-id\",\n  \"quantity\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/cart/items",
          "host": ["{{baseUrl}}"],
          "path": ["cart", "items"]
        }
      }
    },
    {
      "name": "Orders / Checkout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"addressId\": \"seed-buyer-address\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/orders/checkout",
          "host": ["{{baseUrl}}"],
          "path": ["orders", "checkout"]
        }
      }
    },
    {
      "name": "Payments / Create checkout session",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderIds\": [\"order-id-1\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/payments/checkout-session",
          "host": ["{{baseUrl}}"],
          "path": ["payments", "checkout-session"]
        }
      }
    },
    {
      "name": "Admin / Dashboard",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/admin/dashboard",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "dashboard"]
        }
      }
    }
  ]
}
